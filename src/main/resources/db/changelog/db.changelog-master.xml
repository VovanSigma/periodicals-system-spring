<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-users" author="kpi">
        <createTable tableName="app_users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="keycloak_id" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="full_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-periodicals" author="kpi">
        <createTable tableName="periodicals">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="category" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="monthly_price" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-subscriptions" author="kpi">
        <createTable tableName="subscriptions">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_subscription_user" references="app_users(id)"/>
            </column>
            <column name="months" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="total_amount" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-subscription-items" author="kpi">
        <createTable tableName="subscription_items">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscription_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_item_subscription" references="subscriptions(id)"/>
            </column>
            <column name="periodical_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_item_periodical" references="periodicals(id)"/>
            </column>
            <column name="price" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="005-create-payments" author="kpi">
        <createTable tableName="payments">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subscription_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="fk_payment_subscription" references="subscriptions(id)"/>
            </column>
            <column name="amount" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-insert-demo-data" author="kpi">
        <insert tableName="app_users">
            <column name="keycloak_id" value="admin-demo-id"/>
            <column name="email" value="admin@mail.com"/>
            <column name="full_name" value="Admin User"/>
            <column name="role" value="ADMIN"/>
        </insert>
        <insert tableName="app_users">
            <column name="keycloak_id" value="reader-demo-id"/>
            <column name="email" value="reader@mail.com"/>
            <column name="full_name" value="Reader User"/>
            <column name="role" value="READER"/>
        </insert>
        <insert tableName="periodicals">
            <column name="title" value="Наука і техніка"/>
            <column name="description" value="Щомісячний журнал про технології"/>
            <column name="category" value="Science"/>
            <column name="monthly_price" valueNumeric="120.00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
        <insert tableName="periodicals">
            <column name="title" value="Бізнес Україна"/>
            <column name="description" value="Аналітика та економіка"/>
            <column name="category" value="Business"/>
            <column name="monthly_price" valueNumeric="150.00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
        <insert tableName="periodicals">
            <column name="title" value="Спорт тижня"/>
            <column name="description" value="Новини спорту"/>
            <column name="category" value="Sport"/>
            <column name="monthly_price" valueNumeric="90.00"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>
</databaseChangeLog>
